{
    "name": "muhammedsalama/laravel-base",
    "description": "Laravel module generator: one command scaffolds Model, Migration, Enum, Filter+Pagination, Interface, Repository, Service, Form Requests, API Resource, Policy, Controller (Swagger/OA), and Tests.",
    "type": "library",
    "license": "MIT",
    "homepage": "https://github.com/MuhammedMSalama/LaravelBase",
    "keywords": [
        "laravel",
        "module-generator",
        "code-generator",
        "repository-pattern",
        "service-layer",
        "api-resource",
        "artisan",
        "filter",
        "pagination",
        "swagger",
        "openapi",
        "rest-api",
        "enum",
        "policy",
        "api-response",
        "form-request"
    ],
    "authors": [
        {
            "name": "Muhammed Salama",
            "email": "devmuhammedsalama@gmail.com",
            "role": "Maintainer",
            "homepage": "https://github.com/MuhammedMSalama"
        }
    ],
    "support": {
        "docs": "https://github.com/MuhammedMSalama/LaravelBase#readme",
        "issues": "https://github.com/MuhammedMSalama/LaravelBase/issues",
        "source": "https://github.com/MuhammedMSalama/LaravelBase"
    },
    "require": {
        "php": "^8.1",
        "illuminate/contracts": ">=10.0",
        "illuminate/database": ">=10.0",
        "illuminate/http": ">=10.0",
        "illuminate/support": ">=10.0"
    },
    "require-dev": {
        "larastan/larastan": "^2.9|^3.0",
        "laravel/pint": "^1.0",
        "orchestra/testbench": "^8.0|^9.0|^10.0|^11.0",
        "phpunit/phpunit": "^10.5|^11.0|^12.0"
    },
    "suggest": {
        "darkaonline/l5-swagger": "Generate interactive Swagger UI docs from the @OA annotations in generated controllers/resources",
        "zircote/swagger-php": "Required by l5-swagger for parsing @OA doc-block annotations"
    },
    "autoload": {
        "psr-4": {
            "MuhammedSalama\\Base\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "MuhammedSalama\\Base\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "vendor/bin/phpunit",
        "analyse": "vendor/bin/phpstan analyse --memory-limit=512M",
        "pint": "vendor/bin/pint",
        "lint": "vendor/bin/pint --test"
    },
    "extra": {
        "laravel": {
            "providers": [
                "MuhammedSalama\\Base\\BaseServiceProvider"
            ]
        }
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "phpstan/extension-installer": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
