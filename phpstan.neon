includes:
    - vendor/larastan/larastan/extension.neon

parameters:
    level: 5

    paths:
        - src

    # Stubs are templates, not analysable source.
    excludePaths:
        - src/Console/Stubs/*

    ignoreErrors:
        # Traits are meant to be used by the consuming application's classes,
        # so PHPStan reports them as "used zero times" inside the package.
        -
            identifier: trait.unused
